    "audit": {
      "suppressions": [
        {
          "checkId": "tools.exec.fs_tools_disabled_but_exec_enabled",
          "detailIncludes": "codebase-index",
          "reason": "exec is restricted to read-only commands via exec-approvals allowlist (no write/curl binaries); workspace search needs exec."
        },
        {
          "checkId": "tools.exec.allowlist_interpreter_without_strict_inline_eval",
          "reason": "find/sed/awk are egress-locked (no curl/wget/interpreters allowlisted; exec-approvals limits binaries). strictInlineEval re-enable pending a harness-script regression test."
        },
        {
          "checkId": "models.weak_tier",
          "reason": "intentional local-first/privacy; mitigated by the tool-use firewall, read-only Critic, and fail-closed-local model chain."
        },
        {
          "checkId": "security.trust_model.multi_user_heuristic",
          "reason": "single operator (the operator); matrix dm/group allowlist is @you only; not multi-tenant."
        },
        {
          "checkId": "plugins.extensions_no_allowlist",
          "reason": "plugins.allow is a TOTAL allowlist: enabling it disabled 88/98 bundled plugins incl canvas (diffs view-mode), active-memory, document-extract (verified 2026-06-14; prior decisions 2026-06-04 & 2026-06-08). Only one trusted extension (matrix) is present, so breakage risk outweighs the warning."
        }
      ]
    }
